
# Server
PORT=8080
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/botAluguel

# Auth
JWT_SECRET=your-secret-here

# SMS Gateway (Zenvia)
# Obtenha sua chave em: https://app.zenvia.com/home/api
# Sem esta chave, o envio de SMS é simulado (modo mock — código exibido apenas nos logs do servidor)
SMS_API_KEY=your-zenvia-api-key-here

# SMS Sender ID (nome exibido como remetente, máx 11 caracteres, opcional)
SMS_SENDER_ID=BotAluguel

# EFI Bank (PIX)
EFI_CLIENT_ID=your-efi-client-id
EFI_CLIENT_SECRET=your-efi-client-secret
EFI_PIX_KEY=your-pix-key
